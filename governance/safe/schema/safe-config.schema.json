{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://public-trust.github.io/public-trust-dao/schema/safe-config.schema.json",
  "title": "Public Trust DAO — конфиг Safe multisig (тестовая казна)",
  "description": "Машиночитаемое описание Safe multisig сообщества. ТОЛЬКО testnet. Без приватных ключей/сид-фраз. Адреса публичны и проверяемы. См. governance/safe/README.md и docs/GOVERNANCE.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "purpose", "status", "network", "safe", "owners_template", "policy"],
  "properties": {
    "schema": { "type": "string", "description": "Путь/URL схемы (необязательно)." },
    "name": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft-awaiting-operator", "deployed-testnet", "deprecated"],
      "description": "draft — ждём адреса/деплой оператора; deployed-testnet — Safe создан на testnet, адреса заполнены; deprecated — выведен."
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "chain_id", "is_testnet"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "chain_id": { "type": "integer", "minimum": 1 },
        "is_testnet": { "type": "boolean" },
        "explorer": { "type": "string" },
        "rpc_hint": { "type": "string", "description": "Подсказка где взять RPC (НЕ секрет/ключ)." }
      }
    },
    "safe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "threshold", "owners_required", "address", "owners"],
      "properties": {
        "version": { "type": "string" },
        "threshold": { "type": "integer", "minimum": 1 },
        "owners_required": { "type": "integer", "minimum": 1 },
        "address": { "type": ["string", "null"], "pattern": "^0x[0-9a-fA-F]{40}$" },
        "owners": {
          "type": "array",
          "items": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" }
        }
      }
    },
    "owners_template": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["role", "label", "address"],
        "properties": {
          "role": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "address": { "type": ["string", "null"], "pattern": "^0x[0-9a-fA-F]{40}$" }
        }
      }
    },
    "policy": {
      "type": "object",
      "additionalProperties": true,
      "description": "Политика подписей/ролей человекочитаемо."
    },
    "links": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
