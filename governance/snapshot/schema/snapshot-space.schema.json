{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://public-trust.github.io/public-trust-dao/schema/snapshot-space.schema.json",
  "title": "Public Trust DAO — конфиг off-chain пространства голосования (Snapshot)",
  "description": "Машиночитаемый макет Snapshot-пространства. Off-chain голосование (gasless подписи), средства не двигаются. «1 человек = 1 голос» (не плутократия). Без приватных ключей/секретов. См. governance/snapshot/README.md и docs/GOVERNANCE.md.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "purpose", "status", "off_chain_signaling", "space", "network", "settings", "one_person_one_vote", "proposal_types"],
  "properties": {
    "schema": { "type": "string", "description": "Путь/URL схемы (необязательно)." },
    "name": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft-awaiting-operator", "deployed-testnet", "deprecated"],
      "description": "draft — ждём ENS/контроллер/создание оператором; deployed-testnet — пространство создано, идентификаторы заполнены; deprecated — выведено."
    },
    "off_chain_signaling": {
      "type": "boolean",
      "description": "Snapshot голосует off-chain (подпись, без газа) и не двигает средства сам. Должно быть true: рельс «голос — сигнал, исполнение отдельно»."
    },
    "space": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ens", "id", "controller", "url"],
      "properties": {
        "ens": { "type": ["string", "null"] },
        "id": { "type": ["string", "null"] },
        "controller": { "type": ["string", "null"], "pattern": "^0x[0-9a-fA-F]{40}$" },
        "url": { "type": ["string", "null"] },
        "note": { "type": "string" }
      }
    },
    "network": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "chain_id", "is_testnet"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "chain_id": { "type": "string", "pattern": "^[0-9]+$" },
        "is_testnet": { "type": "boolean" },
        "note": { "type": "string" }
      }
    },
    "settings": {
      "type": "object",
      "additionalProperties": true,
      "description": "Настройки пространства в формате Snapshot (для вставки в snapshot.org). Стратегии/валидация проверяются валидатором рельс.",
      "required": ["strategies", "voting"],
      "properties": {
        "strategies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1 }
            }
          }
        },
        "voting": {
          "type": "object",
          "additionalProperties": true,
          "required": ["type", "delay", "period", "quorum"],
          "properties": {
            "type": { "type": "string", "minLength": 1 },
            "delay": { "type": "integer", "minimum": 0 },
            "period": { "type": "integer", "minimum": 0 },
            "quorum": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "one_person_one_vote": {
      "type": "object",
      "additionalProperties": true
    },
    "proposal_types": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["key", "title"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 }
        }
      }
    },
    "lifecycle": { "type": "string" },
    "anti_sybil": { "type": "object", "additionalProperties": true },
    "links": { "type": "object", "additionalProperties": true }
  }
}
